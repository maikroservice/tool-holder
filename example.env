# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
#
# This root .env is for shared variables available to all tools as a fallback.
# Tool-specific secrets should live in tools/<tool_name>/.env instead.

# Example: a shared ATC ingest key used across multiple tools
# (can be overridden per tool in tools/<tool_name>/.env)
INGEST_KEY=atc_your_ingest_key_here
